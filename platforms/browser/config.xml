<?xml version='1.0' encoding='utf-8'?>
<widget id="be.rern.jg" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>Jardin Gourmand</name>
    <description>
       Un essai simple avec Cordova et Framework7
    </description>
    <author email="rol@rern.be" href="http://rern.be">
        Rol
    </author>
    <content src="index.html" />
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />
</widget>
